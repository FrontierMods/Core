[
  {
    id: "sign",
    type: "jmath_function",
    num_args: 1,

    /**
     * ARGUMENTS
     *
     * 0. any numerical value
     */

    // * returns -1 when input value is 0
    return: "_0 > 0 ? 1 : -1",
  },
  {
    id: "random",
    type: "jmath_function",
    num_args: 2,

    /**
     * ARGUMENTS
     *
     * 0. minimum (must be integer)
     * 1. maximum (must be integer), inclusive
     */

    // * returns integer only
    return: "floor( rng( 0, 1 ) * ( floor( _1 ) - ceil( _0 ) + 1 ) + ceil( _0 ) )",
  },
]
